#!/command/with-contenv sh
set -e

# Defaults
: "${SHARE_NAME:=public}"
: "${SHARE_PATH:=/share}"
: "${WORKGROUP:=WORKGROUP}"
: "${SERVER_STRING:=Samba Server}"
: "${FORCE_USER_UID:=1000}"
: "${FORCE_GROUP_GID:=1000}"
: "${SHARE_DIR_MODE:=}"
: "${LOG_LEVEL:=1}"
: "${SAMBA_PASSWORD:=samba}"

ensure_samba_group() {
  if getent group samba >/dev/null; then
    current_gid="$(getent group samba | cut -d: -f3)"
    if [ "${current_gid}" != "${FORCE_GROUP_GID}" ]; then
      echo "Group samba already exists with GID ${current_gid}, expected ${FORCE_GROUP_GID}" >&2
      exit 1
    fi
    return
  fi

  existing_group="$(getent group "${FORCE_GROUP_GID}" | cut -d: -f1 || true)"
  if [ -n "${existing_group}" ]; then
    echo "Requested FORCE_GROUP_GID=${FORCE_GROUP_GID} already belongs to group ${existing_group}" >&2
    exit 1
  fi

  groupadd -g "${FORCE_GROUP_GID}" samba
}

ensure_samba_user() {
  if getent passwd samba >/dev/null; then
    current_uid="$(getent passwd samba | cut -d: -f3)"
    current_gid="$(getent passwd samba | cut -d: -f4)"
    samba_gid="$(getent group samba | cut -d: -f3)"
    if [ "${current_uid}" != "${FORCE_USER_UID}" ] || [ "${current_gid}" != "${samba_gid}" ]; then
      echo "User samba already exists with UID:GID ${current_uid}:${current_gid}, expected ${FORCE_USER_UID}:${samba_gid}" >&2
      exit 1
    fi
    return
  fi

  existing_user="$(getent passwd "${FORCE_USER_UID}" | cut -d: -f1 || true)"
  if [ -n "${existing_user}" ]; then
    echo "Requested FORCE_USER_UID=${FORCE_USER_UID} already belongs to user ${existing_user}" >&2
    exit 1
  fi

  useradd -u "${FORCE_USER_UID}" -g samba -M -s /sbin/nologin samba
}

# Create samba group and user with configurable UID/GID
ensure_samba_group
ensure_samba_user
printf '%s\n%s\n' "${SAMBA_PASSWORD}" "${SAMBA_PASSWORD}" | smbpasswd -a -s samba

# Ensure share directory exists with correct ownership
mkdir -p "${SHARE_PATH}"
chown samba:samba "${SHARE_PATH}"

if [ -n "${SHARE_DIR_MODE}" ]; then
  chmod "${SHARE_DIR_MODE}" "${SHARE_PATH}"
fi

# Optional: restrict access to specific networks
if [ -n "${SAMBA_HOSTS_ALLOW}" ]; then
  HOSTS_ALLOW_LINE="  hosts allow = ${SAMBA_HOSTS_ALLOW}"
else
  HOSTS_ALLOW_LINE=""
fi

# Optional: guest access
if [ "${GUEST_OK}" = "1" ]; then
  GUEST_LINE="  guest ok = yes"
else
  GUEST_LINE="  valid users = samba"
fi

# Optional: follow symlinks
if [ "${FOLLOW_SYMLINKS}" = "1" ]; then
  SYMLINKS_LINE="  follow symlinks = yes
  wide links = yes
  unix extensions = no"
else
  SYMLINKS_LINE=""
fi

# Generate smb.conf from template
export SHARE_NAME SHARE_PATH WORKGROUP SERVER_STRING LOG_LEVEL HOSTS_ALLOW_LINE SYMLINKS_LINE GUEST_LINE
envsubst < /etc/samba/smb.conf.template > /etc/samba/smb.conf

# Optional: restrict Avahi to specific interfaces
if [ -n "${ALLOWED_INTERFACES}" ]; then
  sed -i "s/^#*allow-interfaces=.*/allow-interfaces=${ALLOWED_INTERFACES}/" /etc/avahi/avahi-daemon.conf
fi

# Validate configuration
echo "--- Samba configuration ---"
testparm -s /etc/samba/smb.conf 2>/dev/null
echo "---"
